<?xml version="1.0" encoding="utf-8"?>
<!--
  MSIX package manifest for Kubuno Desktop (Microsoft Store).

  This packages the Tauri Win32 executable as a full-trust MSIX (Desktop Bridge).
  Before submitting to the Store you MUST replace Identity/Name and
  Identity/Publisher with the exact values reserved in Partner Center
  (App management → Product identity), and bump Identity/Version on each upload.
  The Version's 4th component must stay 0 (Store requirement).
-->
<Package
  xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
  xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
  xmlns:desktop="http://schemas.microsoft.com/appx/manifest/desktop/windows10"
  IgnorableNamespaces="uap rescap desktop">

  <Identity
    Name="Kubuno.KubunoDesktop"
    Publisher="CN=Kubuno"
    Version="1.0.0.0"
    ProcessorArchitecture="x64" />

  <Properties>
    <DisplayName>Kubuno Desktop</DisplayName>
    <PublisherDisplayName>Kubuno</PublisherDisplayName>
    <Description>Synchronisation de fichiers Kubuno, offline-first (façon Nextcloud).</Description>
    <Logo>Assets\StoreLogo.png</Logo>
  </Properties>

  <Dependencies>
    <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.22631.0" />
  </Dependencies>

  <Resources>
    <Resource Language="fr-FR" />
    <Resource Language="en-US" />
  </Resources>

  <Capabilities>
    <!-- Full-trust Win32 app: runs as a normal desktop process (file system + network). -->
    <rescap:Capability Name="runFullTrust" />
    <Capability Name="internetClient" />
  </Capabilities>

  <Applications>
    <Application Id="KubunoDesktop"
                Executable="kubuno-desktop.exe"
                EntryPoint="Windows.FullTrustApplication">
      <uap:VisualElements
        DisplayName="Kubuno Desktop"
        Description="Synchronisation de fichiers Kubuno, offline-first."
        BackgroundColor="#1a73e8"
        Square150x150Logo="Assets\Square150x150Logo.png"
        Square44x44Logo="Assets\Square44x44Logo.png">
        <uap:DefaultTile
          Wide310x150Logo="Assets\Wide310x150Logo.png"
          Square71x71Logo="Assets\Square71x71Logo.png"
          Square310x310Logo="Assets\Square310x310Logo.png" />
        <uap:SplashScreen Image="Assets\SplashScreen.png" BackgroundColor="#1a73e8" />
      </uap:VisualElements>
    </Application>
  </Applications>
</Package>
